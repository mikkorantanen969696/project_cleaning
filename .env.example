# Telegram Bot Token
BOT_TOKEN=your_telegram_bot_token_here

# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/project_cleaning

# Admin Configuration
ADMIN_TELEGRAM_ID=your_admin_telegram_id
